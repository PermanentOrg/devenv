{
  "bridges": [
    {
      "name": "trigger_archivematica",
      "queue": {
        "queueUrl": "http://localstack:4566/000000000000/Local_Archivematica_Queue_<DevName>",
        "queueArn": "arn:aws:sqs:us-west-2:000000000000:Local_Archivematica_Queue_<DevName>",
        "endpoint": "http://localstack:4566"
      },
      "lambda": {
        "functionName": "TriggerArchivematicaFunction",
        "endpoint": "http://host.docker.internal:3001"
      },
      "batchSize": 10,
      "waitTimeSeconds": 20,
      "visibilityTimeout": 300,
      "deleteOnError": false
    },
    {
      "name": "record_thumbnail_attacher",
